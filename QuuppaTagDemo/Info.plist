<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>

  <!-- ── Identity ─────────────────────────────────────────────────────── -->
  <key>CFBundleDevelopmentRegion</key>
  <string>en</string>

  <key>CFBundleDisplayName</key>
  <string>QuuppaTag</string>

  <key>CFBundleExecutable</key>
  <string>$(EXECUTABLE_NAME)</string>

  <key>CFBundleIdentifier</key>
  <string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>

  <key>CFBundleInfoDictionaryVersion</key>
  <string>6.0</string>

  <key>CFBundleName</key>
  <string>$(PRODUCT_NAME)</string>

  <key>CFBundlePackageType</key>
  <string>APPL</string>

  <key>CFBundleShortVersionString</key>
  <string>3.0</string>

  <key>CFBundleVersion</key>
  <string>3</string>

  <!-- ── Minimum OS & device ──────────────────────────────────────────── -->
  <!-- iOS 13 required for:
       - CLBeaconRegion initWithUUID: (replaces deprecated initWithProximityUUID:)
       - CBManagerState (replaces deprecated CBPeripheralManagerState)
       - UISheetPresentationController (iOS 15, guarded with @available) -->
  <key>MinimumOSVersion</key>
  <string>13.0</string>

  <key>LSRequiresIPhoneOS</key>
  <true/>

  <key>UIRequiredDeviceCapabilities</key>
  <array>
    <string>armv7</string>
    <string>bluetooth-le</string>
  </array>

  <!-- ── Privacy — Bluetooth ──────────────────────────────────────────── -->
  <!-- NSBluetoothAlwaysUsageDescription is REQUIRED for iOS 13+.
       Without it the app crashes on launch. -->
  <key>NSBluetoothAlwaysUsageDescription</key>
  <string>QuuppaTagDemo uses Bluetooth to broadcast this device as a Quuppa location tag so it can be tracked by the Quuppa Intelligent Locating System.</string>

  <!-- NSBluetoothPeripheralUsageDescription is required for iOS 12 and below. -->
  <key>NSBluetoothPeripheralUsageDescription</key>
  <string>QuuppaTagDemo uses Bluetooth to broadcast this device as a Quuppa location tag so it can be tracked by the Quuppa Intelligent Locating System.</string>

  <!-- ── Background Modes ──────────────────────────────────────────────── -->
  <!-- bluetooth-peripheral: allows CBPeripheralManager to continue
       advertising iBeacon packets when the app enters the background.
       Must also be enabled in Xcode → Signing & Capabilities
       → Background Modes → "Uses Bluetooth LE accessories". -->
  <key>UIBackgroundModes</key>
  <array>
    <string>bluetooth-peripheral</string>
  </array>

  <!-- ── Localisation ──────────────────────────────────────────────────── -->
  <key>CFBundleLocalizations</key>
  <array>
    <string>en</string>
    <string>zh-Hans</string>
  </array>

  <!-- ── Scene Manifest (iOS 13+ multi-scene support) ─────────────────── -->
  <key>UIApplicationSceneManifest</key>
  <dict>
    <key>UIApplicationSupportsMultipleScenes</key>
    <false/>
    <key>UISceneConfigurations</key>
    <dict>
      <key>UIWindowSceneSessionRoleApplication</key>
      <array>
        <dict>
          <key>UISceneConfigurationName</key>
          <string>Default Configuration</string>
          <key>UISceneDelegateClassName</key>
          <string>SceneDelegate</string>
          <key>UISceneStoryboardFile</key>
          <string>Main</string>
        </dict>
      </array>
    </dict>
  </dict>

  <!-- ── UI / Appearance ──────────────────────────────────────────────── -->
  <key>UIMainStoryboardFile</key>
  <string>Main</string>

  <key>UILaunchStoryboardName</key>
  <string>LaunchScreen</string>

  <key>UIStatusBarStyle</key>
  <string>UIStatusBarStyleLightContent</string>

  <!-- Dark mode: always use dark appearance to match the app's dark UI -->
  <key>UIUserInterfaceStyle</key>
  <string>Dark</string>

  <key>UISupportedInterfaceOrientations</key>
  <array>
    <string>UIInterfaceOrientationPortrait</string>
  </array>

  <key>UISupportedInterfaceOrientations~ipad</key>
  <array>
    <string>UIInterfaceOrientationPortrait</string>
    <string>UIInterfaceOrientationPortraitUpsideDown</string>
    <string>UIInterfaceOrientationLandscapeLeft</string>
    <string>UIInterfaceOrientationLandscapeRight</string>
  </array>

</dict>
</plist>
